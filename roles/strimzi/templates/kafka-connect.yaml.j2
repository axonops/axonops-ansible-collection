{# Strimzi KafkaConnect - generated by axonops.axonops.strimzi role #}
{% set _namespace = cluster.namespace | default('kafka') %}
{% set _kafka_version = cluster.kafka_version | default(strimzi_kafka_version) %}
{% set _image = cluster.image | default(strimzi_image) %}
{% set _image_tag = cluster.kafka_connect_image_tag | default(cluster.image_tag | default(strimzi_image_tag)) %}
{% set _replicas = cluster.kafka_connect_replicas | default(strimzi_kafka_connect_replicas) %}
{% set _axon_org = cluster.axon_agent_org | default(strimzi_axon_agent_org) %}
{% set _axon_key = cluster.axon_agent_key | default(strimzi_axon_agent_key) %}
{% set _axon_host = cluster.axon_agent_server_host | default(strimzi_axon_agent_server_host) %}
{% set _axon_port = cluster.axon_agent_server_port | default(strimzi_axon_agent_server_port) %}
{% set _axon_tls = cluster.axon_agent_tls_mode | default(strimzi_axon_agent_tls_mode) %}
{% set _cluster_name = cluster.axon_agent_cluster_name | default(cluster.name) %}
---
apiVersion: kafka.strimzi.io/v1beta2
kind: KafkaConnect
metadata:
  name: {{ cluster.name }}-connect
  namespace: {{ _namespace }}
  annotations:
    strimzi.io/use-connector-resources: "true"
spec:
  version: {{ _kafka_version }}
  image: {{ _image }}:{{ _image_tag }}
  replicas: {{ _replicas }}
  bootstrapServers: {{ cluster.name }}-kafka-bootstrap:9092
  config:
    group.id: connect-group
    config.storage.topic: connect-configs
    status.storage.topic: connect-status
    offset.storage.topic: connect-offsets
    config.storage.replication.factor: -1
    offset.storage.replication.factor: -1
    status.storage.replication.factor: -1
{% if cluster.kafka_connect_config is defined %}
{% for key, value in cluster.kafka_connect_config.items() %}
    {{ key }}: {{ value }}
{% endfor %}
{% endif %}
  template:
    connectContainer:
      env:
        - name: KAFKA_NODE_TYPE
          value: connect
        - name: AXON_AGENT_CLUSTER_NAME
          value: "{{ _cluster_name }}"
        - name: AXON_AGENT_ORG
          value: "{{ _axon_org }}"
        - name: AXON_AGENT_KEY
          value: "{{ _axon_key }}"
        - name: AXON_AGENT_SERVER_HOST
          value: "{{ _axon_host }}"
        - name: AXON_AGENT_SERVER_PORT
          value: "{{ _axon_port }}"
        - name: AXON_AGENT_TLS_MODE
          value: "{{ _axon_tls }}"

{# Strimzi Kafka CR - generated by axonops.axonops.strimzi role #}
{% set _kafka_version = cluster.kafka_version | default(strimzi_kafka_version) %}
{% set _image = cluster.image | default(strimzi_image) %}
{% set _image_tag = cluster.image_tag | default(strimzi_image_tag) %}
{% set _namespace = cluster.namespace | default('kafka') %}
{% set _rack_key = cluster.rack_topology_key | default(strimzi_rack_topology_key) %}
{% set _listeners = cluster.listeners | default(strimzi_listeners) %}
{% set _replication_factor = cluster.default_replication_factor | default(strimzi_default_replication_factor) %}
{% set _min_isr = cluster.min_insync_replicas | default(strimzi_min_insync_replicas) %}
{% set _offsets_rf = cluster.offsets_topic_replication_factor | default(strimzi_offsets_topic_replication_factor) %}
{% set _txn_rf = cluster.transaction_state_log_replication_factor | default(strimzi_transaction_state_log_replication_factor) %}
{% set _txn_min_isr = cluster.transaction_state_log_min_isr | default(strimzi_transaction_state_log_min_isr) %}
---
apiVersion: kafka.strimzi.io/v1beta2
kind: Kafka
metadata:
  name: {{ cluster.name }}
  namespace: {{ _namespace }}
  annotations:
    strimzi.io/node-pools: enabled
    strimzi.io/kraft: enabled
{% if cluster.annotations is defined %}
{{ cluster.annotations | to_nice_yaml(indent=2) | indent(4, false) }}
{% endif %}
{% if cluster.labels is defined %}
  labels:
{{ cluster.labels | to_nice_yaml(indent=2) | indent(4, false) }}
{% endif %}
spec:
  kafka:
    version: {{ _kafka_version }}
    image: {{ _image }}:{{ _image_tag }}
{% if _rack_key | length > 0 %}
    rack:
      topologyKey: {{ _rack_key }}
{% endif %}
    listeners:
{% for listener in _listeners %}
      - name: {{ listener.name }}
        port: {{ listener.port }}
        type: {{ listener.type }}
        tls: {{ listener.tls | lower }}
{% endfor %}
    config:
      offsets.topic.replication.factor: {{ _offsets_rf }}
      transaction.state.log.replication.factor: {{ _txn_rf }}
      transaction.state.log.min.isr: {{ _txn_min_isr }}
      default.replication.factor: {{ _replication_factor }}
      min.insync.replicas: {{ _min_isr }}
{% if cluster.kafka_config is defined %}
{% for key, value in cluster.kafka_config.items() %}
      {{ key }}: {{ value }}
{% endfor %}
{% endif %}
    jvmOptions:
      javaSystemProperties:
        - name: kafka.logs.dir
          value: /var/log/kafka
    logging:
      type: inline
      loggers:
        log4j.rootLogger: "INFO, FILE"
        log4j.appender.FILE: "org.apache.log4j.RollingFileAppender"
        log4j.appender.FILE.File: "/var/log/kafka/server.log"
        log4j.appender.FILE.MaxFileSize: "10MB"
        log4j.appender.FILE.MaxBackupIndex: "5"
        log4j.appender.FILE.layout: "org.apache.log4j.PatternLayout"
        log4j.appender.FILE.layout.ConversionPattern: "[%d] %p %m (%c)%n"
        log4j.logger.axonops.io.netty: "ERROR"

{# Strimzi KafkaNodePool (controller) - generated by axonops.axonops.strimzi role #}
{% set _namespace = cluster.namespace | default('kafka') %}
{% set _controller_replicas = cluster.controller_replicas | default(strimzi_controller_replicas) %}
{% set _controller_storage_size = cluster.controller_storage_size | default(strimzi_controller_storage_size) %}
{% set _controller_storage_class = cluster.controller_storage_class | default(strimzi_controller_storage_class) %}
{% set _rack_key = cluster.rack_topology_key | default(strimzi_rack_topology_key) %}
{% set _axon_org = cluster.axon_agent_org | default(strimzi_axon_agent_org) %}
{% set _axon_key = cluster.axon_agent_key | default(strimzi_axon_agent_key) %}
{% set _axon_host = cluster.axon_agent_server_host | default(strimzi_axon_agent_server_host) %}
{% set _axon_port = cluster.axon_agent_server_port | default(strimzi_axon_agent_server_port) %}
{% set _axon_tls = cluster.axon_agent_tls_mode | default(strimzi_axon_agent_tls_mode) %}
{% set _cluster_name = cluster.axon_agent_cluster_name | default(cluster.name) %}
---
apiVersion: kafka.strimzi.io/v1beta2
kind: KafkaNodePool
metadata:
  name: {{ cluster.name }}-controller
  namespace: {{ _namespace }}
  labels:
    strimzi.io/cluster: {{ cluster.name }}
spec:
  replicas: {{ _controller_replicas }}
  roles:
    - controller
  storage:
    type: jbod
    volumes:
      - id: 0
        type: persistent-claim
        size: {{ _controller_storage_size }}
        deleteClaim: false
{% if _controller_storage_class | length > 0 %}
        class: {{ _controller_storage_class }}
{% endif %}
        kraftMetadata: shared
  template:
    pod:
      topologySpreadConstraints:
        - maxSkew: 1
          topologyKey: {{ _rack_key }}
          whenUnsatisfiable: ScheduleAnyway
          labelSelector:
            matchLabels:
              strimzi.io/name: {{ cluster.name }}
    kafkaContainer:
      env:
        - name: KAFKA_NODE_TYPE
          value: kraft-controller
        - name: AXON_AGENT_CLUSTER_NAME
          value: "{{ _cluster_name }}"
        - name: AXON_AGENT_ORG
          value: "{{ _axon_org }}"
        - name: AXON_AGENT_KEY
          value: "{{ _axon_key }}"
        - name: AXON_AGENT_SERVER_HOST
          value: "{{ _axon_host }}"
        - name: AXON_AGENT_SERVER_PORT
          value: "{{ _axon_port }}"
        - name: AXON_AGENT_TLS_MODE
          value: "{{ _axon_tls }}"
{% if cluster.controller_extra_env is defined %}
{% for env_var in cluster.controller_extra_env %}
        - name: {{ env_var.name }}
          value: "{{ env_var.value }}"
{% endfor %}
{% endif %}

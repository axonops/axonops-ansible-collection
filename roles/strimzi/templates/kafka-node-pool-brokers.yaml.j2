{# Strimzi KafkaNodePool (brokers) - generated by axonops.axonops.strimzi role #}
{% set _namespace = cluster.namespace | default('kafka') %}
{% set _broker_replicas = cluster.broker_replicas | default(strimzi_broker_replicas) %}
{% set _broker_storage_size = cluster.broker_storage_size | default(strimzi_broker_storage_size) %}
{% set _broker_storage_class = cluster.broker_storage_class | default(strimzi_broker_storage_class) %}
{% set _axon_org = cluster.axon_agent_org | default(strimzi_axon_agent_org) %}
{% set _axon_key = cluster.axon_agent_key | default(strimzi_axon_agent_key) %}
{% set _axon_host = cluster.axon_agent_server_host | default(strimzi_axon_agent_server_host) %}
{% set _axon_port = cluster.axon_agent_server_port | default(strimzi_axon_agent_server_port) %}
{% set _axon_tls = cluster.axon_agent_tls_mode | default(strimzi_axon_agent_tls_mode) %}
{% set _cluster_name = cluster.axon_agent_cluster_name | default(cluster.name) %}
---
apiVersion: kafka.strimzi.io/v1beta2
kind: KafkaNodePool
metadata:
  name: {{ cluster.name }}-brokers
  namespace: {{ _namespace }}
  labels:
    strimzi.io/cluster: {{ cluster.name }}
spec:
  replicas: {{ _broker_replicas }}
  roles:
    - broker
  storage:
    type: jbod
    volumes:
      - id: 0
        type: persistent-claim
        size: {{ _broker_storage_size }}
        deleteClaim: false
{% if _broker_storage_class | length > 0 %}
        class: {{ _broker_storage_class }}
{% endif %}
  template:
    kafkaContainer:
      env:
        - name: KAFKA_NODE_TYPE
          value: kraft-broker
        - name: AXON_AGENT_CLUSTER_NAME
          value: "{{ _cluster_name }}"
        - name: AXON_AGENT_ORG
          value: "{{ _axon_org }}"
        - name: AXON_AGENT_KEY
          value: "{{ _axon_key }}"
        - name: AXON_AGENT_SERVER_HOST
          value: "{{ _axon_host }}"
        - name: AXON_AGENT_SERVER_PORT
          value: "{{ _axon_port }}"
        - name: AXON_AGENT_TLS_MODE
          value: "{{ _axon_tls }}"
{% if cluster.broker_extra_env is defined %}
{% for env_var in cluster.broker_extra_env %}
        - name: {{ env_var.name }}
          value: "{{ env_var.value }}"
{% endfor %}
{% endif %}

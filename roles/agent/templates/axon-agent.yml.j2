{% if axon_agent_server_host is defined %}
axon-server:
    hosts: {{ axon_agent_server_host }}
{% if axon_agent_server_port is defined %}
    port: {{ axon_agent_server_port | default(1888) }}
{% endif %}
{% endif %}

axon-agent:
{% if axon_agent_server_host is not defined %}
    prom_only: true
{% endif %}
    org: "{{ axon_agent_customer_name }}"
{% if axon_agent_key is defined %}
    key: {{ axon_agent_key }}
{% endif %}
{% if axon_agent_host_name is defined %}
    host_name: "{{ axon_agent_host_name }}"
{% endif %}
{% if axon_agent_cluster_name is defined %}
    cluster_name: "{{ axon_agent_cluster_name }}"
{% endif %}
{% if axon_agent_OpenTSDB_service_test is defined %}
    host: "{{ ansible_default_ipv4.address }}"
    OpenTSDB_service_test: true
    ssl: false
    port: 9916
{% endif %}
{% if axon_agent_human_readable_identifier is defined %}
    human_readable_identifier: "{{ axon_agent_human_readable_identifier }}"
{% endif %}
{% if axon_agent_force_send_all_metrics_prom is defined %}
    force_send_all_metrics_prom: true
{% endif %}
{% if axon_agent_tmp_path is defined and axon_agent_tmp_path != "" %}
    tmp_path: "{{ axon_agent_tmp_path }}"
{% endif %}
{% if axon_agent_tls_mode is defined and  axon_agent_tls_mode != '' %}
    tls:
      mode: "{{ axon_agent_tls_mode }}" # disabled, TLS, mTLS
{% if axon_agent_tls_mode == "TLS" or axon_agent_tls_mode == "mTLS" %}
      skipVerify: {{ axon_agent_tls_skipverify | default('false') }}
{% if axon_agent_tls_cafile is defined %}
      caFile: "{{ axon_agent_tls_cafile }}"
{% endif %}
{% endif %}
{% if axon_agent_tls_mode is defined and axon_agent_tls_mode == "mTLS" %}
      certFile: "{{ axon_agent_tls_certfile }}"
      keyFile: "{{ axon_agent_tls_keyfile }}"
{% endif %}
{% endif %}
{% if axon_agent_backup_purge_interval is defined %}
    backup_purge_interval: "{{ axon_agent_backup_purge_interval }}"
{% endif %}
    disable_command_exec: {{ axon_agent_disable_command_exec | default(false) | bool }}
    scripts_location: {{ axon_agent_scripts_location | default('/var/lib/axonops/scripts/') }}

{% if axon_agent_ntp_server is defined and axon_agent_ntp_server != "" %}
NTP:
    host: "{{ axon_agent_ntp_server }}" # Specify your NTP server IP address or hostname
    timeout: {{ axon_agent_ntp_timeout | default(6) }}
{% endif %}

{% if axon_agent_include_service_config %}
{% if axon_java_agent.startswith('axon-dse') %}
{{ axon_agent_upper_lower_case_dse_template_var | default('dse') }}:
    tier0: # metrics collected every 5 seconds
        metrics:
            jvm_:
              - "java.lang:*"
            cas_:
              - "org.apache.cassandra.metrics:*"
              - "org.apache.cassandra.net:type=FailureDetector"
              - "com.datastax.bdp:type=dsefs,*"
              - "com.datastax.bdp:type=metrics,*"
    tier1:
        frequency: 300 # metrics collected every 300 seconds (5m)
        metrics:
            cas_:
              #- "org.apache.cassandra.metrics:name=EstimatedPartitionSizeHistogram,*"
              - "org.apache.cassandra.metrics:name=EstimatedPartitionCount,*"
              #- "org.apache.cassandra.metrics:name=EstimatedColumnCountHistogram,*"

    #tier2:
    #    frequency: 3600 # 1h

    #tier3:
    #    frequency: 86400 # 1d

    blacklist: # You can blacklist metrics based on Regex pattern. Hit the agent on http://agentIP:9916/metricslist to list JMX metrics it is collecting
      - "org.apache.cassandra.metrics:type=ColumnFamily.*" # duplication of table metrics
      - "org.apache.cassandra.metrics:.*scope=Repair#.*" # ignore each repair instance metrics
      - "org.apache.cassandra.metrics:.*name=SnapshotsSize.*" # Collecting SnapshotsSize metrics slows down collection
      - "org.apache.cassandra.metrics:.*Max.*"
      - "org.apache.cassandra.metrics:.*Min.*"
      - "com.datastax.bdp:.*Max.*"
      - "com.datastax.bdp:.*Min.*"
      - ".*999thPercentile|.*50thPercentile|.*FifteenMinuteRate|.*FiveMinuteRate|.*MeanRate|.*Mean|.*OneMinuteRate|.*StdDev"
    JMXOperationsBlacklist:
      - "getThreadInfo"
      - "getDatacenter"
      - "getRack"
    DMLEventsWhitelist: # You can whitelist keyspaces / tables (list of "keyspace" and/or "keyspace.table" to log DML queries. Data is not analysed.
    # - "system_distributed"
    DMLEventsBlacklist: # You can blacklist keyspaces / tables from the DMLEventsWhitelist (list of "keyspace" and/or "keyspace.table" to log DML queries. Data is not analysed.
    # - system_distributed.parent_repair_history
    logSuccessfulRepairs: false # set it to true if you want to log all the successful repair events.
    #nodetoolPath : "/path/to/nodetool"
    warningThresholdMillis: 200 # This will warn in logs when a MBean takes longer than the specified value.
    logFormat: "%4$s %1$tY-%1$tm-%1$td %1$tH:%1$tM:%1$tS,%1$tL %5$s%6$s%n"
{% elif "axon-kafka" in axon_java_agent %}
kafka:
{% if inventory_hostname in groups['kafka_controllers'] %}
  node_type: "kraft-controller"
{% elif inventory_hostname in groups['kafka_brokers'] %}
  node_type: "kraft-broker"
{% elif inventory_hostname in groups['kafka_connect'] %}
  node_type: "connect"
{% endif %}
{# axon_agent_rack overrides; otherwise fall back to kafka_rack from the kafka role. #}
{% set _rack = axon_agent_rack | default('') or kafka_rack | default('') %}
{% if _rack | length > 0 %}
  rack: "{{ _rack }}"
{% endif %}
{# Render kafka_client only on hosts that run a broker. The agent talks to
   its co-located broker, not the cluster bootstrap list. Override the
   broker URL by setting axon_agent_kafka_brokers explicitly. #}
{% set _brokers = axon_agent_kafka_brokers | default([]) %}
{% if (_brokers | length == 0) and (inventory_hostname in groups['kafka_brokers'] | default([])) %}
{%   set _brokers = [(kafka_node_ip | default(ansible_default_ipv4.address)) ~ ':9092'] %}
{% endif %}
{% if _brokers | length > 0 %}
  kafka_client:
    brokers:
{% for _broker in _brokers %}
      - "{{ _broker }}"
{% endfor %}
{% if axon_agent_kafka_sasl_enabled | default(false) | bool %}
    sasl:
      mechanism: "{{ axon_agent_kafka_sasl_mechanism | default('PLAIN') }}"
      username: "{{ axon_agent_kafka_sasl_username }}"
      password: "{{ axon_agent_kafka_sasl_password }}"
{% endif %}
{% if axon_agent_kafka_tls_enabled | default(false) | bool %}
    tls:
      enabled: true
{% if axon_agent_kafka_tls_ca_filepath | default('') | length > 0 %}
      caFilepath: "{{ axon_agent_kafka_tls_ca_filepath }}"
{% endif %}
      insecureSkipTlsVerify: {{ axon_agent_kafka_tls_skip_verify | default(false) | bool | string | lower }}
{% endif %}
{% endif %}
{# connect_client — rendered on Connect hosts. Either provide a full
   axon_agent_connect_clusters list, or rely on the shortcut vars to
   build a single-cluster entry. #}
{% if axon_agent_connect_enabled | default(false) | bool %}
{%   set _connect_clusters = axon_agent_connect_clusters | default([]) %}
{%   if _connect_clusters | length == 0 %}
{%     set _connect_clusters = [{
         'name': axon_agent_connect_cluster_name,
         'url': axon_agent_connect_url,
         'username': axon_agent_connect_username | default(''),
         'password': axon_agent_connect_password | default(''),
         'token': axon_agent_connect_token | default(''),
         'tls': {
           'enabled': axon_agent_connect_tls_enabled | default(false),
           'caFilepath': axon_agent_connect_tls_ca_filepath | default(''),
           'certFilepath': axon_agent_connect_tls_cert_filepath | default(''),
           'keyFilepath': axon_agent_connect_tls_key_filepath | default(''),
           'insecureSkipTlsVerify': axon_agent_connect_tls_skip_verify | default(false),
         }
       }] %}
{%   endif %}
  connect_client:
    enabled: true
    clusters:
{% for _c in _connect_clusters %}
      - name: "{{ _c.name }}"
        url: "{{ _c.url }}"
{% if _c.username | default('') | length > 0 %}
        username: "{{ _c.username }}"
        password: "{{ _c.password | default('') }}"
{% endif %}
{% if _c.token | default('') | length > 0 %}
        token: "{{ _c.token }}"
{% endif %}
{% if (_c.tls | default({})).enabled | default(false) | bool %}
        tls:
          enabled: true
{% if _c.tls.caFilepath | default('') | length > 0 %}
          caFilepath: "{{ _c.tls.caFilepath }}"
{% endif %}
{% if _c.tls.certFilepath | default('') | length > 0 %}
          certFilepath: "{{ _c.tls.certFilepath }}"
{% endif %}
{% if _c.tls.keyFilepath | default('') | length > 0 %}
          keyFilepath: "{{ _c.tls.keyFilepath }}"
{% endif %}
          insecureSkipTlsVerify: {{ _c.tls.insecureSkipTlsVerify | default(false) | bool | string | lower }}
{% endif %}
{% endfor %}
    connectTimeout: {{ axon_agent_connect_connect_timeout | default('10s') }}
    readTimeout: {{ axon_agent_connect_read_timeout | default('30s') }}
    requestTimeout: {{ axon_agent_connect_request_timeout | default('30s') }}
    startup:
      establishConnectionEagerly: {{ axon_agent_connect_startup_establish_eagerly | default(false) | bool | string | lower }}
      maxRetries: {{ axon_agent_connect_startup_max_retries | default(5) }}
      retryInterval: {{ axon_agent_connect_startup_retry_interval | default('1s') }}
      maxRetryInterval: {{ axon_agent_connect_startup_max_retry_interval | default('30s') }}
      backoffMultiplier: {{ axon_agent_connect_startup_backoff_multiplier | default(2.0) }}
{% endif %}

{% elif "axon-cassandra" in axon_java_agent %}
cassandra:
    tier0: # metrics collected every 5 seconds
        metrics:
            jvm_:
              - "java.lang:*"
            cas_:
              - "org.apache.cassandra.metrics:*"
              - "org.apache.cassandra.net:type=FailureDetector"

    tier1:
        frequency: 300 # metrics collected every 300 seconds (5m)
        metrics:
            cas_:
              #- "org.apache.cassandra.metrics:name=EstimatedPartitionSizeHistogram,*"
              - "org.apache.cassandra.metrics:name=EstimatedPartitionCount,*"
              #- "org.apache.cassandra.metrics:name=EstimatedColumnCountHistogram,*"

    #tier2:
    #    frequency: 3600 # 1h

    #tier3:
    #    frequency: 86400 # 1d

    blacklist: # You can blacklist metrics based on Regex pattern. Hit the agent on http://agentIP:9916/metricslist to list JMX metrics it is collecting
      - "org.apache.cassandra.metrics:type=ColumnFamily.*" # duplication of table metrics
      - "org.apache.cassandra.metrics:.*scope=Repair#.*" # ignore each repair instance metrics
      - "org.apache.cassandra.metrics:.*name=SnapshotsSize.*" # Collecting SnapshotsSize metrics slows down collection
      - "org.apache.cassandra.metrics:.*Max.*"
      - "org.apache.cassandra.metrics:.*Min.*"
      - ".*999thPercentile|.*50thPercentile|.*FifteenMinuteRate|.*FiveMinuteRate|.*MeanRate|.*Mean|.*OneMinuteRate|.*StdDev"

    DMLEventsWhitelist: # You can whitelist keyspaces / tables (list of "keyspace" and/or "keyspace.table" to log DML queries. Data is not analysed.
      - "system_distributed"

    JMXOperationsBlacklist:
      - "getThreadInfo"
      - "getDatacenter"
      - "getRack"

    logSuccessfulRepairs: false # set it to true if you want to log all the successful repair events.

    warningThresholdMillis: {{ axon_agent_warn_threshold_millis | default(1000) }} # This will warn in logs when a MBean takes longer than the specified value.

    logFormat: "%4$s %1$tY-%1$tm-%1$td %1$tH:%1$tM:%1$tS,%1$tL %5$s%6$s%n"
{% endif %}
{% endif %}

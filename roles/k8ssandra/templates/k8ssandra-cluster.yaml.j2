{# K8ssandraCluster Custom Resource - generated by axonops.axonops.k8ssandra role #}
{% set _cassandra_version = cluster.cassandra_version | default(k8ssandra_cassandra_version) %}
{% set _image = cluster.image | default(k8ssandra_image) %}
{% set _image_tag = cluster.image_tag | default(k8ssandra_image_tag | default(_cassandra_version)) %}
{% set _dc_name = cluster.dc_name | default(k8ssandra_dc_name) %}
{% set _dc_size = cluster.dc_size | default(k8ssandra_dc_size) %}
{% set _storage_class = cluster.storage_class | default(k8ssandra_storage_class) %}
{% set _storage_size = cluster.storage_size | default(k8ssandra_storage_size) %}
{% set _axonops_storage_size = cluster.axonops_storage_size | default(k8ssandra_axonops_storage_size) %}
{% set _cpu_limit = cluster.cpu_limit | default(k8ssandra_cpu_limit) %}
{% set _cpu_request = cluster.cpu_request | default(k8ssandra_cpu_request) %}
{% set _memory_limit = cluster.memory_limit | default(k8ssandra_memory_limit) %}
{% set _memory_request = cluster.memory_request | default(k8ssandra_memory_request) %}
{% set _heap_size = cluster.heap_size | default(k8ssandra_heap_size) %}
{% set _axon_org = cluster.axon_agent_org | default(k8ssandra_axon_agent_org) %}
{% set _axon_key = cluster.axon_agent_key | default(k8ssandra_axon_agent_key) %}
{% set _axon_host = cluster.axon_agent_server_host | default(k8ssandra_axon_agent_server_host) %}
{% set _axon_port = cluster.axon_agent_server_port | default(k8ssandra_axon_agent_server_port) %}
{% set _soft_anti_affinity = cluster.soft_pod_anti_affinity | default(k8ssandra_soft_pod_anti_affinity) %}
apiVersion: k8ssandra.io/v1alpha1
kind: K8ssandraCluster
metadata:
  name: {{ cluster.name }}
  namespace: {{ cluster.namespace | default(k8ssandra_operator_namespace) }}
{% if cluster.labels is defined %}
  labels:
{{ cluster.labels | to_nice_yaml(indent=2) | indent(4, false) }}
{% endif %}
{% if cluster.annotations is defined %}
  annotations:
{{ cluster.annotations | to_nice_yaml(indent=2) | indent(4, false) }}
{% endif %}
spec:
  cassandra:
    serverVersion: "{{ _cassandra_version }}"
    serverImage: {{ _image }}:{{ _image_tag }}
    softPodAntiAffinity: {{ _soft_anti_affinity | lower }}
    resources:
      limits:
        cpu: {{ _cpu_limit }}
        memory: {{ _memory_limit }}
      requests:
        cpu: {{ _cpu_request }}
        memory: {{ _memory_request }}
    datacenters:
      - metadata:
          name: {{ _dc_name }}
        size: {{ _dc_size }}
        containers:
          - name: cassandra
            env:
              - name: AXON_AGENT_KEY
                value: "{{ _axon_key }}"
              - name: AXON_AGENT_ORG
                value: "{{ _axon_org }}"
              - name: AXON_AGENT_SERVER_HOST
                value: "{{ _axon_host }}"
              - name: AXON_AGENT_SERVER_PORT
                value: "{{ _axon_port }}"
{% if cluster.extra_env is defined %}
{% for env_var in cluster.extra_env %}
              - name: {{ env_var.name }}
                value: "{{ env_var.value }}"
{% endfor %}
{% endif %}
        config:
          jvmOptions:
            heap_initial_size: {{ _heap_size }}
            heap_max_size: {{ _heap_size }}
{% if cluster.cassandra_config is defined %}
          cassandraYaml:
{{ cluster.cassandra_config | to_nice_yaml(indent=2) | indent(12, false) }}
{% endif %}
        storageConfig:
          cassandraDataVolumeClaimSpec:
{% if _storage_class | length > 0 %}
            storageClassName: {{ _storage_class }}
{% endif %}
            accessModes:
              - ReadWriteOnce
            resources:
              requests:
                storage: {{ _storage_size }}
        extraVolumes:
          pvcs:
            - name: axonops-data
              mountPath: /var/lib/axonops
              pvcSpec:
{% if _storage_class | length > 0 %}
                storageClassName: {{ _storage_class }}
{% endif %}
                accessModes:
                  - ReadWriteOnce
                resources:
                  requests:
                    storage: {{ _axonops_storage_size }}
{% if cluster.extra_volumes is defined %}
{{ cluster.extra_volumes | to_nice_yaml(indent=2) | indent(8, false) }}
{% endif %}
{% if cluster.additional_datacenters is defined %}
{% for dc in cluster.additional_datacenters %}
      - metadata:
          name: {{ dc.name }}
        size: {{ dc.size | default(_dc_size) }}
        containers:
          - name: cassandra
            env:
              - name: AXON_AGENT_KEY
                value: "{{ dc.axon_agent_key | default(_axon_key) }}"
              - name: AXON_AGENT_ORG
                value: "{{ dc.axon_agent_org | default(_axon_org) }}"
              - name: AXON_AGENT_SERVER_HOST
                value: "{{ dc.axon_agent_server_host | default(_axon_host) }}"
              - name: AXON_AGENT_SERVER_PORT
                value: "{{ dc.axon_agent_server_port | default(_axon_port) }}"
        config:
          jvmOptions:
            heap_initial_size: {{ dc.heap_size | default(_heap_size) }}
            heap_max_size: {{ dc.heap_size | default(_heap_size) }}
        storageConfig:
          cassandraDataVolumeClaimSpec:
{% if (dc.storage_class | default(_storage_class)) | length > 0 %}
            storageClassName: {{ dc.storage_class | default(_storage_class) }}
{% endif %}
            accessModes:
              - ReadWriteOnce
            resources:
              requests:
                storage: {{ dc.storage_size | default(_storage_size) }}
        extraVolumes:
          pvcs:
            - name: axonops-data
              mountPath: /var/lib/axonops
              pvcSpec:
{% if (dc.storage_class | default(_storage_class)) | length > 0 %}
                storageClassName: {{ dc.storage_class | default(_storage_class) }}
{% endif %}
                accessModes:
                  - ReadWriteOnce
                resources:
                  requests:
                    storage: {{ dc.axonops_storage_size | default(_axonops_storage_size) }}
{% endfor %}
{% endif %}

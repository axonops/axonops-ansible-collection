#!/usr/bin/env bash
# Push tuned alerts back to a named customer's cluster.
#
# Reads tuning/customers/<name>.env for ORG and CLUSTER, then exec's
# tuning/tuned-apply. apply-tuned-alerts defaults --input to the conventional
# tuned-path under cli/exported/<org>/<cluster>/; override with --input.
#
# Usage:
#   tuning/apply-customer <name> [--dry-run | --yes] [extra apply-tuned-alerts args...]
#
# Required env:
#   AXONOPS_TOKEN   — SaaS API token (base URL is auto-detected by the CLI)
set -euo pipefail

NAME="${1:?usage: tuning/apply-customer <name> [--dry-run | --yes] [extra args...]}"
shift || true

TUNING_DIR="$(cd "$(dirname "$0")" && pwd)"
CONF="${TUNING_DIR}/customers/${NAME}.env"

if [[ ! -f "$CONF" ]]; then
    echo "no customer config at ${CONF}" >&2
    echo "available customers:" >&2
    ls "${TUNING_DIR}/customers/" 2>/dev/null | sed 's|\.env$||;s|^|  |' >&2
    exit 2
fi
# shellcheck source=/dev/null
source "$CONF"

: "${ORG:?customer config ${CONF} missing ORG}"
: "${CLUSTER:?customer config ${CONF} missing CLUSTER}"

exec "${TUNING_DIR}/tuned-apply" "$ORG" "$CLUSTER" "$@"

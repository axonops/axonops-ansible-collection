# Template customer config. Copy to <name>.env, fill in the required keys, and
# uncomment the optional ones you need. Loaded as bash KEY=VALUE pairs by the
# bin/tune-customer, bin/cycle-customer, and bin/apply-customer scripts.

# Required ────────────────────────────────────────────────────────────────────
ORG=                       # AxonOps organisation name
CLUSTER=                   # AxonOps cluster name
HOT_KEYSPACE=              # the cluster's active keyspace
HOT_TABLE=                 # the hottest-read-latency table inside HOT_KEYSPACE
                           # (visible in the AxonOps UI: Cassandra > Tables,
                           # sort by p99 read latency)

# Optional tune knobs (override bin/tune CLI defaults if set) ─────────────────
# DAYS=30                  # lookback window in days (CLI default 7)
# MIN_SAMPLES=30           # let sparse-but-real metrics through (default 100)
# MAX_DELTA=30             # accept larger workload-derived shifts (default 10)
# EXTRA_SET_LABELS=("table=${HOT_TABLE}")
                           # extra --set-label values, one per array element.
                           # Use when the cluster's rules carry an additional
                           # label (e.g. a separate `table` label) on top of
                           # the keyspace + cas_Table_*:scope pins that
                           # bin/tune-customer already issues.

# Optional schema-fix patcher ─────────────────────────────────────────────────
# EXPR_PATCHER=patch-<name>-broken-exprs
                           # Path relative to bin/. Only set if the cluster's
                           # metric label schema diverges from what the shipped
                           # default rules assume (e.g. when the chart-derived
                           # exprs filter on labels that don't exist on the
                           # cluster). When set, bin/cycle-customer runs the
                           # script, applies its alert_rules.schemafix.json
                           # output via apply-tuned-alerts, and re-exports
                           # before tuning — so the tune sees the corrected
                           # stored exprs.

# Optional pre-cycle hooks ────────────────────────────────────────────────────
# PRE_HOOKS=("fix-<name>-some-dashboard-chart")
                           # Bash array of paths relative to bin/. Each script
                           # is run at the very start of bin/cycle-customer,
                           # before the first export. Use for idempotent
                           # setup steps (e.g. dashboard chart corrections)
                           # that should be enforced on every cycle. Failures
                           # stop the cycle, so keep hooks idempotent.
